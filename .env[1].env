# ═══════════════════════════════════════
# AuditPro Server — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════

# Server port (3000 is default)
PORT=3000

# Secret key for login tokens — change this to any random long string
JWT_SECRET=auditpro_secret_change_this_in_production_2026

# Database file location (SQLite for easy local testing)
DB_PATH=./auditpro.db

# Your company name (shown in the app)
COMPANY_NAME=AuditPro
